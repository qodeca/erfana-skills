{
  "$schema": "../brand.schema.json",
  "id": "example-acme",
  "displayName": "ACME Corp (example)",
  "legalName": "ACME Corporation, Fictitious Entity",
  "version": "0.1.0",
  "tokens": "./tokens.tokens.json",
  "logos": [
    { "id": "primary", "src": "./logo/example-acme-primary.svg", "usage": ["light-bg", "marketing"] }
  ],
  "typography": {
    "primary": "Inter",
    "display": "Inter Display",
    "mono": "JetBrains Mono"
  },
  "voice": {
    "attributes": ["playful", "warm", "approachable"],
    "doNotUse": ["jargon", "doom-and-gloom phrasing"],
    "watermark": "Made by ACME Corp",
    "guide": "./voice.md"
  },
  "imagery": {
    "illustrationStyle": "./illustration.md"
  },
  "platforms": ["web", "print"]
}
